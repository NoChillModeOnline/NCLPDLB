# ============================================================
# Pokemon Draft League Bot — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================

# ── DEPLOYMENT TARGET ────────────────────────────────────────
# Options: "free" (Fly.io + Cloudflare R2) | "azure"
DEPLOY_TARGET=free

# ── DISCORD ──────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_GUILD_ID=your_test_server_guild_id  # For dev/testing only
BOT_NAME=DraftBot                            # Display name used in embeds and logs
BOT_STATUS=Pokemon Draft League             # Watching "..." text shown under the bot

# ── GOOGLE SHEETS ────────────────────────────────────────────
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# ── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./pokemon_draft.db
# For Azure SQL (Path B):
# DATABASE_URL=mssql+pyodbc://user:pass@server.database.windows.net/dbname?driver=ODBC+Driver+18+for+SQL+Server

# ── POKEMON API ──────────────────────────────────────────────
POKEAPI_BASE_URL=https://pokeapi.co/api/v2
POKEAPI_RATE_LIMIT=100  # requests per minute

# ── SHOWDOWN ─────────────────────────────────────────────────
SHOWDOWN_DATA_URL=https://raw.githubusercontent.com/smogon/pokemon-showdown/master/config/formats.ts
SHOWDOWN_TIERS_URL=https://raw.githubusercontent.com/smogon/pokemon-showdown/master/data/formats-data.ts

# Showdown bot account for /spar live challenges (optional)
# Create a free Showdown account at https://play.pokemonshowdown.com
# The bot uses this account to send challenges to users
SHOWDOWN_USERNAME=
SHOWDOWN_PASSWORD=

# ML policy models directory (where trained PPO models are stored)
ML_POLICY_DIR=data/ml/policy

# ── VIDEO STORAGE (Path A — Cloudflare R2) ───────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=pokemon-draft-videos
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── VIDEO STORAGE (Path B — Azure Blob) ──────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER=match-videos

# ── WEB API ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_to_a_long_random_secret
CORS_ORIGINS=http://localhost:5173,https://your-dashboard.pages.dev

# ── FFMPEG (Optional — for video thumbnails) ─────────────────
# Windows:  C:/ffmpeg/bin/ffmpeg.exe (install via: winget install Gyan.FFmpeg)
# macOS:    /opt/homebrew/bin/ffmpeg  (install via: brew install ffmpeg)
# Linux:    /usr/bin/ffmpeg            (install via: sudo apt install ffmpeg)
FFMPEG_PATH=ffmpeg  # Uses PATH by default; override if needed

# ── SMOGON / VGC ─────────────────────────────────────────────
SMOGON_STRATEGY_URL=https://www.smogon.com/dex
VGC_FORMAT=reg-h  # Current VGC regulation set

# ── ELO ──────────────────────────────────────────────────────
ELO_K_FACTOR=32
ELO_DEFAULT_RATING=1000

# ── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
