# ── VIDEO STORAGE (Path B — Azure Blob) ──────────────────────
# Leave blank if not using Azure
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=match-videos

# ── WEB API ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_to_a_long_random_secret_32chars
CORS_ORIGINS=http://localhost:5173

# ── FFMPEG (Optional — for video thumbnails) ─────────────────
FFMPEG_PATH=ffmpeg

# ── SMOGON / VGC ─────────────────────────────────────────────
SMOGON_STRATEGY_URL=https://www.smogon.com/dex
VGC_FORMAT=reg-h

# ── ELO ──────────────────────────────────────────────────────
ELO_K_FACTOR=32
ELO_DEFAULT_RATING=1000

# ── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
