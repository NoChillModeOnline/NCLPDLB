# Docker ignore file - don't include these in Docker image

# Git
.git
.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Credentials (will be provided via environment variables)
.credentials.json
service-account.json
.env
*.env

# Test files
test_*.py
*_test.py
tests/

# Documentation (not needed in container)
*.md
docs/

# Logs
*.log

# Temporary files
*.tmp
temp/
tmp/

# Build artifacts
dist/
build/
*.egg

# Large files
*.zip
*.tar.gz
